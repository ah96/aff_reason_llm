# Experiment outputs (data, not code)
out_b/
outputs/
cache_b/
experiments/experiment_b_bundle/out/
# ultralytics SAM/YOLO prediction-image junk (created despite save=False)
runs/
# Scratch logs (e.g. experiment_b_bundle/_fetch.log)
*.log

# API keys / secrets
.env
*.env
secrets.json

# OS
.DS_Store
Thumbs.db

# Editor / tool directories
.idea/
.vscode/
*.swp
*.swo

# Datasets (too large for git)
data/
datasets/
ade_affordance/

# Paper — kept on Overleaf, not GitHub
overleaf/

# Reference material / PDFs (large, not needed to run anything)
related_work/
*.pdf

# Experiment A data + cache + raw predictions (archived separately).
# Keeps the small summary *.json + score_from_raw.py + results/README.md trackable.
experiments/experiment_a_bundle/
experiments/experiment_a/cache_a_vision/
experiments/experiment_a/results/*.jsonl

# Experiment B — SAM checkpoints (auto-downloaded) + archived dead code
experiments/experiment_b/checkpoints/
experiments/experiment_b/legacy/
# experiment_b_agreement.py writes agree_*.json to its CWD; keep the canonical copies only under results/
experiments/experiment_b/agree_*.json
# NOTE: experiments/experiment_b/results/ (raw jsonl snapshot + agree_*.json summaries from snapshot_results.py)
# is intentionally COMMITTED & pushable — it is small (~few MB) and flows lab PC -> git -> laptop for
# analysis + paper writing. Only the runner's working out/ + cache_b/ stay ignored (see above).
# NOTE: experiments/experiment_b_bundle/images/ is intentionally NOT ignored — the 200 scenes
# are committed so the lab PC gets them on `git pull`.
